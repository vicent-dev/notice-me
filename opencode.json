{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "second_constantine/deepseek-coder-v2:16b": {
          "name": "DeepSeek Coder V2 16B (local)"
        },
        "qwen3.6:latest": {
          "name": "Qwen 3.6 (local)"
        }
      }
    }
  },
  "default_agent": "orchestrator",
  "instructions": ["AGENTS.md"],
  "agent": {
    "orchestrator": {
      "description": "Orchestrates the harness development pipeline across spec-generator, implementer, and verifier subagents",
      "mode": "primary",
      "color": "primary",
      "permission": {
        "edit": "deny",
        "bash": "allow",
        "task": "allow",
        "read": "allow"
      }
    },
    "spec-generator": {
      "description": "Produces ultra-technical SDD documents for each task: exact file changes, struct signatures, data flow, test plan, edge cases",
      "mode": "subagent",
      "hidden": true,
      "color": "info",
      "permission": {
        "edit": "deny",
        "bash": "allow",
        "read": "allow",
        "task": "allow"
      }
    },
    "implementer": {
      "description": "Reads an SDD and implements the specified changes, then verifies compilation",
      "mode": "subagent",
      "hidden": true,
      "color": "success",
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "read": "allow",
        "task": "allow"
      }
    },
    "verifier": {
      "description": "Runs tests and compilation checks after implementation; reports pass/fail with details",
      "mode": "subagent",
      "hidden": true,
      "color": "warning",
      "permission": {
        "edit": "deny",
        "bash": "allow",
        "read": "allow",
        "task": "allow"
      }
    },
    "git-agent": {
      "description": "Stages, commits, pushes a branch, and opens a GitHub pull request",
      "mode": "subagent",
      "hidden": true,
      "color": "success",
      "permission": {
        "edit": "deny",
        "bash": "allow",
        "read": "allow",
        "task": "deny"
      }
    }
  }
}
